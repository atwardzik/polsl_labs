.PHONY: clean

CC ?= clang
LINKER ?= clang

CC_ARGS = -Wall -Wextra -Wpedantic -Werror \
		-Wno-unused-variable -Wno-unused-parameter -Wno-sign-compare \
		-Wno-unused-function -Wno-unneeded-internal-declaration \
		-Iinclude -Ibuild \
		-std=c23 -c -g -O0


SRCDIR := src
BUILDDIR := build
OBJDIR := obj
BINDIR := bin

OBJS = \
	$(OBJDIR)/y.tab.o \
	$(OBJDIR)/ast.o \
	$(OBJDIR)/compiler.o \
	$(OBJDIR)/main.o

# top level
all: dirs debug

clean:
	@rm -rf build/ bin/ obj/ debug

dirs:
	@mkdir -p $(BUILDDIR) $(OBJDIR) $(BINDIR)

# flex and bison
$(BUILDDIR)/y.tab.c $(BUILDDIR)/y.tab.h: $(SRCDIR)/parser.y $(BUILDDIR)/lex.yy.c
	yacc -v -d -o $(BUILDDIR)/y.tab.c $<

$(BUILDDIR)/lex.yy.c: $(SRCDIR)/lexer.l
	flex -o $@ $<


# compilation rules
$(OBJDIR)/y.tab.o: $(BUILDDIR)/y.tab.c
	$(CC) $(CC_ARGS) -c $< -o $@

$(OBJDIR)/ast.o: $(SRCDIR)/ast.c
	$(CC) $(CC_ARGS) -c $< -o $@

$(OBJDIR)/compiler.o: $(SRCDIR)/compiler.c
	$(CC) $(CC_ARGS) -c $< -o $@

$(OBJDIR)/main.o: $(SRCDIR)/main.c
	$(CC) $(CC_ARGS) -c $< -o $@


# all
$(BINDIR)/debug: $(OBJS)
	$(LINKER) -o $@ $(OBJS)

debug: $(BINDIR)/debug

compile_commands:
	@bear -- make clean all